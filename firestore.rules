rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Check if ID is alphanumeric (safe from injection)
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Match user accounts
    match /users/{phoneNumber} {
      allow read: if true; // Allow read for verification
      allow create, update: if isValidId(phoneNumber) && request.resource.data.phoneNumber == phoneNumber;
      allow delete: if false;
    }

    // Match active drafts
    match /drafts/{phoneNumber} {
      allow read, write: if isValidId(phoneNumber);
    }
  }
}
